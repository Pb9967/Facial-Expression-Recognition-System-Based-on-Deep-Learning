# ============================================================================
# 全局默认：让 Git 自动判断文本/二进制，检出时按平台处理，提交时统一为 LF
# ============================================================================
* text=auto

# ============================================================================
# 代码与配置文件：强制使用 LF（消除 Windows 下的 CRLF 警告）
# ============================================================================
*.py      text eol=lf
*.pyx     text eol=lf
*.pxd     text eol=lf
*.json    text eol=lf
*.xml     text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.ini     text eol=lf
*.cfg     text eol=lf
*.md      text eol=lf
*.txt     text eol=lf

# OpenCV DNN 网络结构描述文件，保持 LF 消除警告
*.prototxt text eol=lf

# Windows 批处理脚本例外：保留 CRLF
*.bat     text eol=crlf
*.cmd     text eol=crlf

# ============================================================================
# 二进制文件：明确标记，Git 不处理换行符，也不生成 diff
# ============================================================================

# 模型权重与序列化数据
*.pth     binary
*.pt      binary
*.ckpt    binary
*.pkl     binary
*.onnx    binary
*.tflite  binary
*.pb      binary

# OpenCV DNN 人脸检测权重（约 10MB）
*.caffemodel binary

# Dlib 68 点模型（约 97MB）
*.dat     binary

# 图像与视频
*.jpg     binary
*.jpeg    binary
*.png     binary
*.bmp     binary
*.gif     binary
*.tif     binary
*.tiff    binary
*.mp4     binary
*.avi     binary
*.mov     binary

# 数据与文档
*.csv     binary
*.xlsx    binary
*.xls     binary
*.db      binary
*.sqlite  binary
*.pdf     binary
*.doc     binary
*.docx    binary

# 压缩包
*.zip     binary
*.tar     binary
*.gz      binary
*.rar     binary
*.7z      binary